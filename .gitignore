venv/
.venv/
env/

# IDEs
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Excel temporales
~$*.xlsx
~$*.xls

# Scripts temporales
patch.py
write_app.py
app_new.py

# Logs
*.log
